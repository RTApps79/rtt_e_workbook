<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Percentage Depth Dose (PDD) Explorer</title>
<style>
  :root{ --blue:#0056b3; --violet:#7c3aed; --panel:#0f1622; --ink:#e8eef7; }
  *{box-sizing:border-box;}
  body{font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;margin:0;background:#f4f4f4;color:#222;}
  header.nav{background:#fff;box-shadow:0 1px 3px rgba(0,0,0,.1);position:sticky;top:0;z-index:50;}
  header.nav .inner{max-width:1150px;margin:0 auto;padding:12px 20px;display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;gap:8px;}
  header.nav strong{color:var(--blue);}
  header.nav a{font-size:.8rem;color:#fff;font-weight:500;padding:8px 12px;border-radius:6px;text-decoration:none;}
  .wrap{max-width:1150px;margin:0 auto;padding:18px;}
  h1{color:var(--blue);text-align:center;margin:.2em 0;}
  .lead{max-width:840px;margin:0 auto 16px;text-align:center;color:#333;}
  .app{display:grid;grid-template-columns:minmax(0,1fr) 350px;gap:18px;align-items:start;}
  @media(max-width:920px){.app{grid-template-columns:1fr;}}
  .stage{background:var(--panel);border-radius:10px;padding:14px;}
  svg{width:100%;height:auto;display:block;}
  .panel{background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:16px;margin-bottom:14px;}
  .panel h3{color:var(--blue);margin:0 0 10px;font-size:1.05rem;}
  label.cl{display:block;font-size:.82rem;font-weight:600;color:#334;margin:10px 0 4px;}
  label.cl .val{float:right;font-weight:400;color:var(--blue);}
  input[type=range]{width:100%;} select{width:100%;padding:8px;border:1px solid #cbd5e1;border-radius:6px;}
  .formula{background:#f0f6ff;border:1px solid #cfe0ff;border-radius:8px;padding:12px;text-align:center;font-size:1rem;color:#123;}
  .formula .big{font-size:1.15rem;font-weight:700;color:var(--blue);margin-top:6px;}
  .readout{background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:10px;font-size:.9rem;}
  .readout div{display:flex;justify-content:space-between;padding:3px 0;} .readout b{color:var(--blue);}
  .rc{background:#fffdf5;border:1px solid #f0e2b8;border-radius:10px;padding:16px;margin-bottom:14px;}
  .rc h3{color:#b45309;margin:0 0 6px;font-size:1.05rem;}
  .rc .scenario{background:#fff;border:1px solid #eee;border-radius:8px;padding:10px;font-size:.92rem;}
  .rc .formula2{text-align:center;margin:10px 0;font-size:1rem;color:#123;font-weight:600;}
  .rc-instr{font-size:.85rem;color:#66571f;margin:8px 0 4px;}
  table.rc-table{width:100%;border-collapse:collapse;}
  table.rc-table td{padding:5px 6px;border-top:1px solid #f0e2b8;vertical-align:middle;}
  table.rc-table .sym{font-weight:700;color:#7c3aed;width:150px;font-size:.95rem;}
  table.rc-table select{width:100%;padding:6px;border:1px solid #cbd5e1;border-radius:6px;font-size:.85rem;}
  table.rc-table .mark{width:22px;text-align:center;font-weight:700;}
  .rc-check{margin-top:10px;padding:8px 14px;border:none;border-radius:6px;background:#b45309;color:#fff;cursor:pointer;font-weight:600;}
  .rc-fb{margin-top:8px;font-weight:600;font-size:.9rem;}
  .locked{opacity:.45;pointer-events:none;filter:grayscale(.3);}
  .unlock-note{font-size:.8rem;color:#b45309;margin-bottom:8px;}
  details{background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:12px 18px;margin-top:14px;}
  summary{font-weight:600;color:var(--blue);cursor:pointer;} .note{font-size:.8rem;color:#667;}
  .footer{text-align:center;margin:22px 0 8px;font-size:.85rem;color:#667;}
</style>
</head>
<body>
<header class="nav">
  <div class="inner">
    <strong>PDD Explorer</strong>
    <div style="display:flex;flex-wrap:wrap;gap:8px;">
      <a href="../index.html" style="background:#0056b3;">&larr; Medical Dosimetry Menu</a>
      <a href="../TMR_PDD/index.html" style="background:#7c3aed;">TMR &amp; Conversion</a>
      <a href="../Beam_Dose_Simulator/index.html" style="background:#7c3aed;">Beam &amp; Dose Simulator</a>
    </div>
  </div>
</header>

<div class="wrap">
  <h1>Percentage Depth Dose (PDD)</h1>
  <p class="lead">PDD is the dose at a given depth expressed as a percentage of the dose at d<sub>max</sub>, along the central axis of an SSD setup. It rises to 100% at d<sub>max</sub> then falls with depth &mdash; and that fall-off depends on <strong>energy</strong>, <strong>field size</strong>, and <strong>SSD</strong>. Change each and watch the curve respond.</p>

  <div class="rc" id="rc">
    <h3>Step 1 &mdash; Read the problem and identify the variables</h3>
    <p class="unlock-note">Map each variable to the correct value from the scenario. The explorer unlocks once your reading is correct.</p>
  </div>

  <div class="app" id="calcApp">
    <div>
      <div class="stage">
        <svg id="plot" viewBox="0 0 700 340" aria-label="PDD curve"></svg>
        <div class="lead" style="color:#9fb2cc;font-size:.8rem;margin-top:8px;">Higher energy, larger field, and longer SSD all raise the PDD at depth. The dashed line marks your reference depth.</div>
      </div>
    </div>
    <div>
      <div class="panel">
        <h3>Beam &amp; Setup</h3>
        <label class="cl">Energy</label>
        <select id="energy"></select>
        <label class="cl">Field size (square) <span class="val" id="fVal">15 cm</span></label>
        <input type="range" id="field" min="4" max="40" value="15">
        <label class="cl">SSD <span class="val" id="ssdVal">100 cm</span></label>
        <input type="range" id="ssd" min="80" max="150" value="100">
        <label class="cl">Reference depth d <span class="val" id="dVal">10 cm</span></label>
        <input type="range" id="depth" min="0" max="30" value="10">
      </div>
      <div class="panel">
        <h3>The Math</h3>
        <div class="formula">
          <div>PDD = 100 &times; (D<sub>depth</sub> / D<sub>dmax</sub>)</div>
          <div class="big" id="mathLine"></div>
        </div>
        <div class="readout" style="margin-top:12px;">
          <div><span>d<sub>max</sub> (this energy)</span><b id="rDmax"></b></div>
          <div><span>PDD at reference depth</span><b id="rPDD"></b></div>
          <div><span>vs. 6 MV, 10&times;10, 100 cm</span><b id="rComp"></b></div>
        </div>
        <p class="note" style="margin-top:8px;">SSD dependence uses the Mayneord F factor (inverse-square based). This is an illustrative model calibrated to typical values.</p>
      </div>
    </div>
  </div>

  <details open>
    <summary>What changes the PDD, and why</summary>
    <p><strong>Energy &uarr;</strong> &rarr; more penetrating, higher PDD at depth and deeper d<sub>max</sub>. <strong>Field size &uarr;</strong> &rarr; more scattered dose reaching depth, higher PDD. <strong>SSD &uarr;</strong> &rarr; higher PDD at depth, because the inverse-square fall-off across the patient is gentler when the source is farther away (the <a href="../Inverse_Square_Law/index.html">inverse square law</a> again). PDD is tied to an SSD setup; for isocentric (SAD) setups we use <a href="../TMR_PDD/index.html">TMR</a> instead, which removes the distance dependence.</p>
  </details>

  <div class="footer">Radiation Therapy E-Workbook &mdash; Medical Dosimetry</div>
</div>

<script>
function readingCheck(mount, cfg, onPass){
  const opts = cfg.quantities.map((q,i)=>`<option value="${i}">${q.label}</option>`).join('')
    + `<option value="unknown">the unknown &mdash; solve for this</option><option value="na">not given</option>`;
  let html=`<p class="scenario">${cfg.scenario}</p><div class="formula2">${cfg.formula}</div><p class="rc-instr">Match each variable to the correct quantity:</p><table class="rc-table">`;
  cfg.variables.forEach((v,i)=>{ html+=`<tr><td class="sym">${v.sym}</td><td><select data-i="${i}"><option value="">&mdash; choose &mdash;</option>${opts}</select></td><td class="mark" data-m="${i}"></td></tr>`; });
  html+=`</table><button class="rc-check">Check my reading</button><div class="rc-fb"></div>`;
  mount.innerHTML=mount.innerHTML+html;
  mount.querySelector('.rc-check').addEventListener('click',()=>{ let all=true,got=0;
    cfg.variables.forEach((v,i)=>{ const sel=mount.querySelector(`select[data-i="${i}"]`),mk=mount.querySelector(`[data-m="${i}"]`);
      const val=sel.value===''?null:((sel.value==='unknown'||sel.value==='na')?sel.value:parseInt(sel.value));
      const ok=String(val)===String(v.answer); mk.textContent=sel.value===''?'':(ok?'\u2713':'\u2717'); mk.style.color=ok?'#15803d':'#b91c1c'; if(ok)got++;else all=false; });
    const fb=mount.querySelector('.rc-fb'); fb.style.color=all?'#15803d':'#b45309';
    fb.textContent=all?'All correct \u2014 the explorer is unlocked below.':`${got}/${cfg.variables.length} correct. Re-read and fix the \u2717 rows.`;
    if(all&&onPass)onPass(); });
}
readingCheck(document.getElementById('rc'),{
  scenario:"A <b>6 MV</b> photon beam with a <b>15 &times; 15 cm</b> field is set up at <b>100 cm SSD</b>. You need the percentage depth dose at a depth of <b>10 cm</b>.",
  formula:"PDD depends on: depth, energy, field size, SSD",
  quantities:[{label:"10 cm"},{label:"15 cm"},{label:"100 cm"},{label:"6 MV"}],
  variables:[
    {sym:"Depth d", answer:0},{sym:"Field size", answer:1},
    {sym:"SSD", answer:2},{sym:"Energy", answer:3},{sym:"PDD (result)", answer:"unknown"}
  ]
},()=>{document.getElementById('calcApp').classList.remove('locked');});
document.getElementById('calcApp').classList.add('locked');

const SVGNS="http://www.w3.org/2000/svg";
function el(t,a){const e=document.createElementNS(SVGNS,t);for(const k in a)e.setAttribute(k,a[k]);return e;}
const ENERGIES=[{id:"co60",label:"Cobalt-60",dmax:0.5,mu:0.063,skin:35},{id:"6mv",label:"6 MV",dmax:1.5,mu:0.047,skin:16},
 {id:"10mv",label:"10 MV",dmax:2.5,mu:0.040,skin:12},{id:"15mv",label:"15 MV",dmax:3.0,mu:0.035,skin:10},{id:"18mv",label:"18 MV",dmax:3.3,mu:0.033,skin:9}];
let energy=ENERGIES[1], field=15, ssd=100, depth=10;
const $=id=>document.getElementById(id);

function skinRise(d,e){ return e.skin+(100-e.skin)*(1-Math.cos(Math.PI/2*d/e.dmax)); }
function muEff(e,f){ return e.mu*(1-0.08*Math.log(f/10)); }
function mayneord(d,e,s){ const dm=e.dmax; return Math.pow((s+dm)/(100+dm),2)*Math.pow((100+d)/(s+d),2); }
function pdd(d,e,f,s){ if(d<=e.dmax) return skinRise(d,e); const base=100*Math.exp(-muEff(e,f)*(d-e.dmax)); return d<=e.dmax?base:base*mayneord(d,e,s); }

function draw(){
  const P=$('plot'); P.innerHTML=''; const W=700,H=340,pl=48,pb=30,pt=12,pr=14, maxD=30;
  const gx=d=>pl+(d/maxD)*(W-pl-pr), gy=v=>pt+(1-v/108)*(H-pt-pb);
  for(let v=0;v<=100;v+=20){ P.appendChild(el('line',{x1:pl,y1:gy(v),x2:W-pr,y2:gy(v),stroke:'#1c2740'})); const t=el('text',{x:10,y:gy(v)+4,fill:'#9fb2cc','font-size':11}); t.textContent=v+'%'; P.appendChild(t); }
  for(let d=0;d<=maxD;d+=5){ const t=el('text',{x:gx(d)-6,y:H-10,fill:'#9fb2cc','font-size':11}); t.textContent=d; P.appendChild(t); }
  P.appendChild(el('line',{x1:pl,y1:pt,x2:pl,y2:H-pb,stroke:'#33405a'})); P.appendChild(el('line',{x1:pl,y1:H-pb,x2:W-pr,y2:H-pb,stroke:'#33405a'}));
  const xl=el('text',{x:W/2-40,y:H-1,fill:'#9fb2cc','font-size':11}); xl.textContent='Depth (cm)'; P.appendChild(xl);
  // reference 6MV 10x10 100 curve (faint)
  let ref='M'; for(let d=0;d<=maxD;d+=0.5){ const v=pdd(d,ENERGIES[1],10,100); ref+=`${gx(d)},${gy(Math.min(108,v))} `+(d===0?'L':''); }
  P.appendChild(el('path',{d:ref,fill:'none',stroke:'#475569','stroke-width':1.5,'stroke-dasharray':'4 4'}));
  // current curve
  let path='M'; for(let d=0;d<=maxD;d+=0.25){ const v=pdd(d,energy,field,ssd); path+=`${gx(d)},${gy(Math.min(108,v))} `+(d===0?'L':''); }
  P.appendChild(el('path',{d:path,fill:'none',stroke:'#e74c3c','stroke-width':2.5}));
  // dmax marker
  P.appendChild(el('circle',{cx:gx(energy.dmax),cy:gy(100),r:4,fill:'#fbbf24'}));
  const dmt=el('text',{x:gx(energy.dmax)+4,y:gy(100)-6,fill:'#fbbf24','font-size':10}); dmt.textContent='d_max'; P.appendChild(dmt);
  // reference depth line + point
  const pv=pdd(depth,energy,field,ssd);
  P.appendChild(el('line',{x1:gx(depth),y1:pt,x2:gx(depth),y2:H-pb,stroke:'#38bdf8','stroke-dasharray':'3 3',opacity:.8}));
  P.appendChild(el('circle',{cx:gx(depth),cy:gy(Math.min(108,pv)),r:4,fill:'#38bdf8'}));
  // readouts
  $('fVal').textContent=field+' cm'; $('ssdVal').textContent=ssd+' cm'; $('dVal').textContent=depth+' cm';
  $('rDmax').textContent=energy.dmax.toFixed(1)+' cm';
  $('rPDD').textContent=pv.toFixed(1)+'%';
  $('mathLine').textContent=`PDD(${depth} cm) = ${pv.toFixed(1)}%`;
  const refv=pdd(depth,ENERGIES[1],10,100);
  $('rComp').textContent=(pv-refv>=0?'+':'')+(pv-refv).toFixed(1)+' pts';
}
const es=$('energy'); ENERGIES.forEach(e=>{const o=document.createElement('option');o.value=e.id;o.textContent=e.label;es.appendChild(o);}); es.value='6mv';
es.addEventListener('change',e=>{energy=ENERGIES.find(x=>x.id===e.target.value); draw();});
$('field').addEventListener('input',e=>{field=+e.target.value; draw();});
$('ssd').addEventListener('input',e=>{ssd=+e.target.value; draw();});
$('depth').addEventListener('input',e=>{depth=+e.target.value; draw();});
draw();
</script>
</body>
</html>
